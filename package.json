{
  "name": "ai-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"tina,runner,watcher\" --prefix-colors \"cyan,yellow,green\" \"tinacms dev -c 'next dev'\" \"$HOME/actions-runner/run.sh\" \"python3 tools/watch.py\"",
    "dev:tina": "tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@tinacms/cli": "^2.2.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tinacms": "^3.7.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
